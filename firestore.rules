rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone (even visitors) can read the products shown on the storefront.
    match /products/{id} {
      allow read: if true;
      // Only the admin account (YOUNES) may write. The admin Firebase account
      // is created in the console with this email + the password cat-mouse-dog-shin.
      allow write: if request.auth != null
                   && request.auth.token.email == "gsys12759@gmail.com";
    }

    // User profiles (username + role). A user may read all (so sign-up can check
    // for a taken username) and may only create/update their own profile.
    match /users/{uid} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
